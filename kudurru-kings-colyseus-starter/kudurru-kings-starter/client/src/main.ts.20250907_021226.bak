import "./h2h.css";
import { buildShell, wireControls, renderState } from "./h2h";
import { Client, Room } from "colyseus.js";

type State = any;

const app = document.getElementById("app")!;
app.innerHTML = buildShell();

const client = new Client(`ws://${location.hostname}:2567`);
let room: Room<State> | null = null;
let last: State | null = null;

function setState(st:State){ last = st; renderState(st, room); }

wireControls({
  async onJoin(){
    if (room) return; // prevent double-joins
    try { room = await client.joinOrCreate<State>("kudurru"); }
    catch { room = await client.joinOrCreate<State>("my_room"); }
    room.onStateChange((st:State)=> setState(st));
    // Convenience for testing: reveal AI
    room.send("toggle", {key:"revealAI", value:true});
  },
  onNext:   ()=> room?.send("action", {type:"NEXT_PHASE"}),
  onBots:   ()=> room?.send("admin",  {type:"ADD_BOTS", count:3}),
  onDeal6:  ()=> room?.send("admin",  {type:"DEAL6"}),
  onReset:  ()=> room?.send("admin",  {type:"RESET_MATCH"}),
  onAiStep: ()=> room?.send("admin",  {type:"AI_TICK"}),
  onReveal: ()=> room?.send("toggle", {key:"revealAI", value: !(last as any)?.revealAI}),
  onSandbox:()=> room?.send("toggle", {key:"sandbox",  value: !(last as any)?.sandbox}),
  onTutorial:()=> {
    const el = document.getElementById("analyzer"); if(!el) return;
    const ph = (last as any)?.phase ?? "Upkeep";
    el.innerHTML = [
      `<b>Tutorial — ${ph}</b>`,
      ph==="Upkeep" ? "Upkeep refreshes resources. Click Next Phase to enter Main."
      : ph==="Main" ? "Click a card from your hand to play. Then advance to Battle."
      : "Click your attacker, then an enemy defender. Choose the test axis."
    ].join("<br/>");
  },
  onOpenLibrary:()=> {
    alert("Library UI will open here (stub)."); // hook your existing modal
  },
  onCmd:(cmd)=> { console.log("[CMD]",cmd); /* wire your game actions here */ }
});
