/* ===== Kudurru Kings UI (Mesopotamian + neon circuitry) ===== */
:root{
  --card-scale:1.5;
  --bg0:#070c14; --bg1:#0b1522; --bg2:#0e1d2f;
  --panel:#0f1e33; --border:#1b2c46; --border2:#2a466e;
  --text:#eaf3ff; --muted:#a8c0e0; --gold:#caa86c; --gold2:#f8d88a; --blue:#3ea6ff;
}

*{box-sizing:border-box}
html,body{height:100%}
body{
  margin:0; color:var(--text); font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, "Helvetica Neue", Arial;
  background:
    radial-gradient(120% 140% at 70% -10%, #12253c 0, #091220 60%),
    linear-gradient(#08101a,#0b1522);
  overflow-y:overlay;
}
body::after{
  content:""; position:fixed; inset:0; pointer-events:none; opacity:.16; mix-blend-mode:screen;
  background:
    repeating-linear-gradient(90deg, transparent 0 118px, rgba(61,168,255,.08) 118px 120px),
    repeating-linear-gradient(0deg, transparent 0 118px, rgba(61,168,255,.06) 118px 120px);
  filter: drop-shadow(0 0 12px rgba(57,210,255,.06));
}

/* Header / toolbar */
header{
  position:sticky; top:0; z-index:5; background:linear-gradient(180deg, #0c1626, #0a1320);
  border-bottom:1px solid var(--border);
  padding:14px 16px;
}
h1{ margin:0 0 8px 0; font-size:20px; letter-spacing:.3px }
.row{ display:flex; flex-wrap:wrap; gap:8px }
button{
  background:#13243d; border:1px solid #203a60; color:#d8ecff; border-radius:10px; padding:6px 10px; cursor:pointer;
  transition:transform .08s ease, box-shadow .12s ease, border-color .12s ease;
}
button:hover{ border-color:var(--blue); box-shadow:0 0 0 2px rgba(62,166,255,.2) inset }
button:active{ transform:translateY(1px) }
label input[type=range]{ vertical-align:middle; accent-color:var(--blue) }
#phase{ opacity:.95 }

/* Layout */
.col{ display:grid; grid-template-columns: 1fr 2fr 1fr; gap:12px; padding:12px }
.panel{
  background:var(--panel); border:1px solid var(--border); border-radius:14px; padding:10px; min-height:120px;
  box-shadow: inset 0 0 0 1px rgba(62,166,255,.08), 0 10px 20px rgba(0,0,0,.25);
}
.tip{ color:var(--muted) }
#log{ max-height:240px; overflow:auto; font-size:13px }
.grid{ display:flex; flex-direction:column; gap:14px }
.player{ border:1px solid var(--border); border-radius:12px; padding:8px; background:rgba(13,28,48,.45) }
.player .area{ margin-top:8px }
.player .bf, .player .hand{
  display:flex; flex-wrap:wrap; gap:14px; align-items:flex-start;
  min-height:calc(330px*var(--card-scale) + 8px);
}
.hidden{ display:none }

/* badges */
.badge{ display:inline-block; margin-left:8px; padding:2px 6px; border-radius:6px; border:1px solid #1e324d; font-weight:800; font-size:11px }
.badge.good{ background:#11325a; color:#d7efff }

/* ===== Card ===== */
.card{
  position:relative; overflow:hidden; border-radius:18px;
  width: calc(210px * var(--card-scale)); height: calc(320px * var(--card-scale));
  background:#0b1a2b;
  box-shadow:0 14px 28px rgba(0,0,0,.45), inset 0 0 0 3px rgba(230,200,120,.18), 0 0 0 1px rgba(62,166,255,.18);
  isolation:isolate;
}
.card::before{
  content:""; position:absolute; inset:0; pointer-events:none; z-index:2;
  background:radial-gradient(140% 90% at 50% 0,#213a66 0%,#0b1a2b 70%) no-repeat;
  mix-blend-mode:screen; opacity:.9; border-radius:18px;
}
.card::after{
  content:""; position:absolute; inset:10px; border-radius:14px; pointer-events:none; z-index:1;
  background:radial-gradient(closest-side, rgba(57,210,255,.18), transparent 68%), repeating-linear-gradient(135deg, rgba(62,166,255,.12) 0 2px, transparent 2px 8px);
  filter:blur(0.3px) saturate(1.2); opacity:.6;
}
.card .pip{
  position:absolute; padding:3px 7px; border-radius:12px; background:rgba(15,30,50,.92); border:1px solid #3a5a86; font-weight:800;
  font-size: calc(11px * var(--card-scale)); color:#e9f3ff; text-shadow:0 1px 0 rgba(0,0,0,.4);
}
.pip.tl{ top:6px; left:6px } .pip.tr{ top:6px; right:6px }
.pip.bl{ bottom:6px; left:6px } .pip.br{ bottom:6px; right:6px }
.card .art{ position:absolute; top:12%; left:50%; transform:translateX(-50%); font-size: calc(78px * var(--card-scale)); filter: drop-shadow(0 2px 2px rgba(0,0,0,.6)); z-index:0; }
.card .title{
  position:absolute; bottom:22%; left:8%; right:8%; text-align:center; background:linear-gradient(180deg,#1b2b45,#15263f);
  border:1px solid #456089; border-radius:10px; padding:6px 8px; font-weight:800; letter-spacing:.2px;
  font-size: calc(15px * var(--card-scale)); color:#f2f6ff; box-shadow: inset 0 0 0 1px rgba(240,220,140,.12), 0 4px 12px rgba(0,0,0,.35);
}
.card .type{ position:absolute; bottom:7%; left:12%; right:12%; text-align:center; font-size: calc(12px * var(--card-scale)); color:#c9dbff; opacity:.9; letter-spacing:.3px; }
.card:hover{ transform:translateY(-2px); box-shadow:0 14px 32px rgba(0,0,0,.55), 0 0 0 3px rgba(62,166,255,.32); transition:transform .12s ease, box-shadow .12s ease }

/* Tooltips for pips */
.card .pip[data-tip]{ position:relative }
.card .pip[data-tip]:hover::after{
  content:attr(data-tip); position:absolute; left:50%; transform:translateX(-50%); bottom:calc(100% + 6px); white-space:nowrap; z-index:10;
  background:#0d1c31; color:#dfefff; border:1px solid #315585; border-radius:8px; padding:5px 8px; font-size:12px; box-shadow:0 8px 16px rgba(0,0,0,.35);
}

/* Analyzer */
#analyzer{ font-size:13px; line-height:1.4 }
#analyzer .line{ padding:2px 0; border-bottom:1px dashed #24405f }
#analyzer .line:last-child{ border-bottom:none }
