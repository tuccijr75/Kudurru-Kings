const fWorldEl  = document.getElementById("fWorld")  as HTMLSelectElement;
const fRarityEl = document.getElementById("fRarity") as HTMLSelectElement;
const fTypeEl   = document.getElementById("fType")   as HTMLSelectElement;
const fTextEl   = document.getElementById("fText")    as HTMLInputElement;
const showAllEl = document.getElementById("showAll")  as HTMLInputElement;

[fWorldEl,fRarityEl,fTypeEl].forEach(el=> el.addEventListener("change", ()=>{ fWorld=fWorldEl.value; fRarity=fRarityEl.value; fType=fTypeEl.value; renderLibrary(); }));
fTextEl.addEventListener("input", ()=>{ fText=fTextEl.value.toLowerCase(); renderLibrary(); });
showAllEl.addEventListener("change", ()=>{ showAll = showAllEl.checked; renderLibrary(); });

function matchCard(c:any){
  if (fWorld && c.world !== fWorld) return false;
  if (fRarity && c.rarity !== fRarity) return false;
  if (fType && c.type !== fType) return false;
  if (fText && !String(c.name).toLowerCase().includes(fText)) return false;
  return true;
}
function libCard(c:any){
  const inDeck = deckSet.has(c.id);
  const inHand = handSet.has(c.id);
  const canDeck = deckSet.size < 36 || inDeck;
  const canHand = handSet.size < 6 || inHand;
  return `<div class="card" data-lid="${c.id}">
    <div class="inner">
      <div class="face front">
        <span class="pip tl">${c.costs.sinew}🪨</span>
        <span class="pip tr">${c.costs.sigil}✴️</span>
        <span class="pip bl">${c.costs.oath}🤝</span>
        <span class="pip br">${String(c.rarity).toUpperCase()}</span>
        <div class="art">${esc(c.emoji||"🗡️")}</div>
        <div class="title">${esc(c.name)}</div>
        <div class="type"><span class="chip world">${esc(c.world)}</span> <span class="chip rar">${esc(c.rarity)}</span> — ${esc(c.type)} • ⚔️ ${c.power} • 🛡️ ${c.armor}</div>
        <div class="lib-actions">
          <button class="mini ${inDeck?"on":""}" data-act="deck" ${canDeck?"":"disabled"}>${inDeck?"✓ In Deck":"Add to Deck"}</button>
          <button class="mini ${inHand?"on":""}" data-act="hand" ${canHand?"":"disabled"}>To Hand</button>
        </div>
      </div>
      <div class="face back">
        <div class="statrow"><div>Text</div><div>${esc(c.text||"—")}</div></div>
      </div>
    </div>
  </div>`;
}
function renderLibrary(){
  const worlds = Array.from(new Set(LIBRARY.map(c=>c.world))).sort();
  const types  = Array.from(new Set(LIBRARY.map(c=>c.type))).sort();
  const rars   = Array.from(new Set(LIBRARY.map(c=>c.rarity))).sort();
  fWorldEl.innerHTML  = '<option value="">World: All</option>' + worlds.map(w=>`<option>${w}</option>`).join("");
  fTypeEl.innerHTML   = '<option value="">Type: All</option>' + types.map(t=>`<option>${t}</option>`).join("");
  fRarityEl.innerHTML = '<option value="">Rarity: All</option>' + rars.map(r=>`<option>${r}</option>`).join("");

  const src = showAll ? LIBRARY : LIBRARY.slice(0, 200); // (toggle simply demonstrates scale)
  const list = src.filter(matchCard);
  $("#libGrid").innerHTML = list.map(libCard).join("");

  $("#deckCount").textContent = String(deckSet.size);
  $("#handCount").textContent = String(handSet.size);
  $("#deckList").innerHTML = Array.from(deckSet).map(id=> `<div>${esc(LIBRARY.find(c=>c.id===id)?.name||id)}</div>`).join("");
  $("#handList").innerHTML = Array.from(handSet).map(id=> `<div>${esc(LIBRARY.find(c=>c.id===id)?.name||id)}</div>`).join("");

  $$("#libGrid .card").forEach(el=>{
    const id = (el as HTMLElement).dataset.lid!;
    (el.querySelector('[data-act="deck"]') as HTMLElement).addEventListener("click",(e)=>{
      e.stopPropagation();
      if (deckSet.has(id)) deckSet.delete(id); else if (deckSet.size<36) deckSet.add(id);
      renderLibrary();
    });
    (el.querySelector('[data-act="hand"]') as HTMLElement).addEventListener("click",(e)=>{
      e.stopPropagation();
      if (handSet.has(id)) handSet.delete(id); else if (handSet.size<6) handSet.add(id);
      renderLibrary();
    });
    el.addEventListener("dblclick", ()=> el.classList.toggle("flipped"));
  });
}

// Boot: load external library and render filters
(async ()=>{
  LIBRARY = await loadLibrary();
  const worlds = Array.from(new Set(LIBRARY.map(c=>c.world))).sort();
  const types  = Array.from(new Set(LIBRARY.map(c=>c.type))).sort();
  const rars   = Array.from(new Set(LIBRARY.map(c=>c.rarity))).sort();
  renderFilterBar(worlds, types, rars);
})();