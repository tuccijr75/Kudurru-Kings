// Load external library (generated by PowerShell)
async function loadLibrary(): Promise<any[]> {
  try {
    const res = await fetch("/assets-library.json", { cache: "no-store" });
    if (!res.ok) return [];
    const data = await res.json();
    return Array.isArray(data) ? data : [];
  } catch { return []; }
}

