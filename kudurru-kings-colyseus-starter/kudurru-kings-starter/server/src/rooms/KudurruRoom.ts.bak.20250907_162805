import { Room, Client } from "colyseus";
import { Schema, type, MapSchema, ArraySchema } from "@colyseus/schema";

/** --- SCHEMA TYPES --- */
class Costs extends Schema {
  @type("int8") sinew: number = 0;  // 🪨
  @type("int8") sigil: number = 0;  // ✴️
  @type("int8") oath:  number = 0;  // 🤝
}
class Card extends Schema {
  @type("string") id: string = "";
  @type("string") name: string = "";
  @type("string") type: string = "";   // Character | Pet | Relic | Name | Site | Boss
  @type("string") rank: string = "";   // Low | Mid | High
  @type([ "int8" ]) aspects = new ArraySchema<number>(0,0,0,0,0); // Stone,Wind,Veil,Oath,Eye
  @type(Costs) costs = new Costs();
  @type("int8") lawUpkeep: number = 0;
  @type("string") text: string = "";
  @type("string") emoji: string = "";
}
class Pools extends Schema {
  @type("int8") sinew: number = 3;
  @type("int8") sigil: number = 2;
  @type("int8") oath:  number = 2;
}
class Player extends Schema {
  @type("string") id: string = "";
  @type("string") name: string = "";
  @type("boolean") ai: boolean = false;
  @type(Pools) pools = new Pools();
  @type("int8") heat: number = 0;
  @type("int8") marks: number = 0;

  @type([ Card ]) deck = new ArraySchema<Card>();
  @type([ Card ]) hand = new ArraySchema<Card>();
  @type([ Card ]) chars = new ArraySchema<Card>();
  @type([ Card ]) names = new ArraySchema<Card>();
  @type([ Card ]) relics = new ArraySchema<Card>();
  @type([ Card ]) pets = new ArraySchema<Card>();
  @type([ Card ]) bound = new ArraySchema<Card>();

  @type([ "string" ]) sites = new ArraySchema<string>();
}
class KudurruState extends Schema {
  @type({ map: Player }) players = new MapSchema<Player>();
  @type("int8") activeIndex: number = 0;
  @type("string") phase: string = "Upkeep";
  @type("int16") turn: number = 1;
  @type([ "string" ]) log = new ArraySchema<string>();
  @type("boolean") sandbox: boolean = true;
  @type("boolean") revealAI: boolean = true;

  // ephemeral engagement
  @type("string") atkPid: string = "";
  @type("string") defPid: string = "";
  @type("string") atkCid: string = "";
  @type("string") defCid: string = "";
  @type("string") test: string = "";
  @type("string") cons: string = "";

  // post-engagement analyzer lines
  @type([ "string" ]) analysis = new ArraySchema<string>();
}

/** --- HELPERS / CONTENT --- */
function uid() { return Math.random().toString(36).slice(2, 10); }
const TYPES = { CHAR:"Character", PET:"Pet", RELIC:"Relic", NAME:"Name", SITE:"Site", BOSS:"Boss" };
const RANKS = { LOW:"Low", MID:"Mid", HIGH:"High" };
const cost = (s=0,g=0,o=0)=>{ const c=new Costs(); c.sinew=s;c.sigil=g;c.oath=o; return c; };
function copyCosts(c: Costs){ return cost(c.sinew, c.sigil, c.oath); }

function makeCard(p: Partial<Card>): Card {
  const c = new Card();
  c.id = uid();
  c.name = p.name || "Card";
  c.type = p.type || TYPES.CHAR;
  c.rank = p.rank || RANKS.LOW;
  c.text = p.text || "";
  c.emoji = p.emoji || "🗡️";
  c.aspects = new ArraySchema<number>(...(p.aspects || [1,1,1,1,1]));
  c.costs = p.costs ? copyCosts(p.costs as Costs) : cost(1,0,0);
  c.lawUpkeep = (p as any).lawUpkeep || 0;
  return c;
}

